{
  "wsPort": 9980,
  "templates": [
    {
      "id": "rasengan",
      "name": "Rasengan",
      "toxPath": "td/templates/rasengan.tox",
      "parameters": [
        { "id": "spin",      "label": "Spin Speed",  "type": "slider", "range": { "min": 0,   "max": 5,   "step": 0.01 }, "defaultValue": 1.0 },
        { "id": "scale",     "label": "Scale",       "type": "slider", "range": { "min": 0.1, "max": 3.0, "step": 0.01 }, "defaultValue": 1.0 },
        { "id": "intensity", "label": "Intensity",   "type": "slider", "range": { "min": 0,   "max": 1,   "step": 0.01 }, "defaultValue": 0.5 },
        { "id": "hue",       "label": "Hue Shift",   "type": "slider", "range": { "min": 0,   "max": 360, "step": 1    }, "defaultValue": 0   },
        { "id": "palmX",     "label": "Palm X",      "type": "slider", "range": { "min": 0,   "max": 1,   "step": 0.001 }, "defaultValue": 0.5, "internal": true },
        { "id": "palmY",     "label": "Palm Y",      "type": "slider", "range": { "min": 0,   "max": 1,   "step": 0.001 }, "defaultValue": 0.5, "internal": true }
      ]
    }
  ]
}
